# Local .terraform directories
**/.terraform/*
**/.terraformrc

# .terraform.lock.hcl (state file, can be included)
.terraform.lock.hcl

# Terraform state files (never commit)
*.tfstate
*.tfstate.*
.terraform.tfstate
.terraform.tfstate.backup

# Terraform plan files
*.tfplan
*.tfplan.binary

# Crash log files
crash.log
crash.*.log
hashicorp.log

# Ignore all .tfvars files (sensitive data)
*.tfvars
*.tfvars.json

# Terraform modules (downloaded)
*.zip
src/

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Local environment variables
.env
.env.local